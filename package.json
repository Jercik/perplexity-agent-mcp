{
  "name": "perplexity-agent-mcp",
  "version": "1.3.0",
  "description": "An opinionated, coding-specialized, Model Context Protocol server that integrates Perplexity AI's Sonar models into AI coding assistants like Claude Code or Codex CLI.",
  "keywords": [
    "ai",
    "mcp",
    "modelcontextprotocol",
    "perplexity"
  ],
  "homepage": "https://github.com/Jercik/perplexity-agent-mcp#readme",
  "bugs": {
    "url": "https://github.com/Jercik/perplexity-agent-mcp/issues"
  },
  "license": "MIT",
  "author": "Łukasz Jerciński",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jercik/perplexity-agent-mcp.git"
  },
  "bin": {
    "perplexity-agent-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsgo --build tsconfig.app.json --force",
    "format": "oxfmt --config .oxfmtrc.json .",
    "format:check": "oxfmt --check --config .oxfmtrc.json .",
    "fta": "fta-check",
    "knip": "knip",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives .",
    "prepack": "pnpm build",
    "prepare": "if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then git config core.hooksPath .githooks; fi",
    "start": "node dist/index.js",
    "test": "PERPLEXITY_API_KEY=dummy-api-key vitest run",
    "typecheck": "tsgo -b --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@j4k/oxlint-config": "^2.11.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "beta",
    "fta-check": "^1.5.2",
    "fta-cli": "^3.0.0",
    "knip": "^6.6.3",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.23.0",
    "semantic-release": "^25.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.8.0"
}
